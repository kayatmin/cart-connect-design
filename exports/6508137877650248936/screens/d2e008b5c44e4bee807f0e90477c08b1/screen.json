                       \"tertiary-container\": \"#2e1b03\",\n                        \"danger-red\": \"#B42318\",\n                        \"outline-variant\": \"#c4c6cd\",\n                        \"on-primary-fixed-variant\": \"#39485d\",\n                        \"ink-dark\": \"#07111F\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"surface\": \"#fbf9fa\",\n                        \"background\": \"#fbf9fa\",\n                        \"on-tertiary-container\": \"#a0815f\",\n                        \"tertiary-fixed\": \"#ffddb9\",\n                        \"on-secondary-container\": \"#fefcff\",\n                        \"surface-tint\": \"#505f75\",\n                        \"on-surface-variant\": \"#44474c\",\n                        \"on-secondary-fixed-variant\": \"#003ea8\",\n                        \"error-container\": \"#ffdad6\",\n                        \"text-tertiary\": \"#8A94A6\",\n                        \"surface-container-low\": \"#f5f3f5\",\n                        \"secondary-container\": \"#316bf3\",\n                        \"container-success-bg\": \"#E7F6EE\",\n                        \"on-error-container\": \"#93000a\",\n                        \"container-danger-bg\": \"#FDECEC\"\n                    },\n                    \"borderRadius\": {\n                        \"DEFAULT\": \"0.25rem\",\n                        \"lg\": \"0.5rem\",\n                        \"xl\": \"0.75rem\",\n                        \"full\": \"9999px\"\n                    },\n                    \"spacing\": {\n                        \"xl\": \"24px\",\n                        \"page-margin\": \"16px\",\n                        \"xs\": \"4px\",\n                        \"section-gap\": \"20px\",\n                        \"2xl\": \"32px\",\n                        \"md\": \"12px\",\n                        \"2xs\": \"2px\",\n                        \"touch-target-min\": \"44px\",\n                        \"button-height\": \"52px\",\n                        \"3xl\": \"48px\",\n                        \"sm\": \"8px\",\n                        \"lg\": \"16px\"\n                    },\n                    \"fontFamily\": {\n                        \"metadata\": [\"Work Sans\"],\n                        \"section-title\": [\"Plus Jakarta Sans\"],\n                        \"data-tabular\": [\"IBM Plex Mono\"],\n                        \"label\": [\"Work Sans\"],\n                        \"display\": [\"Plus Jakarta Sans\"],\n                        \"body-strong\": [\"Work Sans\"],\n                        \"body\": [\"Work Sans\"],\n                        \"screen-title\": [\"Plus Jakarta Sans\"],\n                        \"card-title\": [\"Plus Jakarta Sans\"]\n                    },\n                    \"fontSize\": {\n                        \"metadata\": [\"11px\", {\"lineHeight\": \"14px\", \"fontWeight\": \"500\"}],\n                        \"section-title\": [\"17px\", {\"lineHeight\": \"24px\", \"fontWeight\": \"700\"}],\n                        \"data-tabular\": [\"13px\", {\"lineHeight\": \"18px\", \"fontWeight\": \"600\"}],\n                        \"label\": [\"12px\", {\"lineHeight\": \"16px\", \"fontWeight\": \"600\"}],\n                        \"display\": [\"28px\", {\"lineHeight\": \"34px\", \"fontWeight\": \"700\"}],\n                        \"body-strong\": [\"14px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"600\"}],\n                        \"body\": [\"14px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"400\"}],\n                        \"screen-title\": [\"22px\", {\"lineHeight\": \"28px\", \"fontWeight\": \"700\"}],\n                        \"card-title\": [\"15px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"700\"}]\n                    }\n                }\n            }\n        }\n    </script>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-bg-base text-on-surface min-h-screen flex flex-col\">\n<!-- TopAppBar -->\n<header class=\"flex items-center justify-between px-4 h-14 w-full z-50 sticky top-0 bg-[#FFFFFF] text-[#102033] border-b border-slate-200\">\n<div class=\"flex items-center gap-4\">\n<button class=\"material-symbols-outlined text-[#102033] active:opacity-80 transition-all\">menu</button>\n<h1 class=\"text-lg font-extrabold tracking-tighter text-[#102033] uppercase font-['Plus_Jakarta_SANS']\">CartConnect</h1>\n</div>\n<div class=\"flex items-center gap-3\">\n<div class=\"w-8 h-8 rounded-full bg-surface-muted flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-sm\">notifications</span>\n</div>\n</div>\n</header>\n<!-- Main Content: Empty State Area -->\n<main class=\"flex-1 flex flex-col items-center justify-center px-page-margin mb-32\">\n<!-- Status Indicator Rail (Industrial Discipline) -->\n<div class=\"w-full max-w-sm bg-surface-white rounded-xl border border-border-soft overflow-hidden relative\">\n<!-- Tonal Layering & Grid Discipline -->\n<div class=\"absolute left-0 top-0 bottom-0 w-1 bg-container-success-text\"></div>\n<div class=\"p-10 flex flex-col items-center text-center\">\n<!-- Calm Visual Icon -->\n<div class=\"w-20 h-20 bg-container-success-bg rounded-full flex items-center justify-center mb-6\">\n<span class=\"material-symbols-outlined text-container-success-text text-4xl\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n</div>\n<!-- Headline -->\n<h2 class=\"font-display text-display text-text-primary mb-3\">All Clear</h2>\n<!-- Subtext -->\n<p class=\"font-body text-body text-text-secondary max-w-[240px]\">\n                    No waiting sessions at the moment. Your station is ready for traffic.\n                </p>\n<!-- Operations Console Decorative Data -->\n<div class=\"mt-10 pt-6 border-t border-surface-muted w-full flex justify-around\">\n<div class=\"flex flex-col gap-1\">\n<span class=\"font-metadata text-metadata text-text-tertiary uppercase tracking-wider\">Status</span>\n<span class=\"font-data-tabular text-data-tabular text-container-success-text uppercase\">Operational</span>\n</div>\n<div class=\"flex flex-col gap-1\">\n<span class=\"font-metadata text-metadata text-text-tertiary uppercase tracking-wider\">Queue</span>\n<span class=\"font-data-tabular text-data-tabular text-text-primary\">0 Active</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Secondary Visual Detail (Optional Contextual Layer) -->\n<div class=\"mt-10 flex items-center gap-3 px-4 py-2 bg-surface-muted rounded-full border border-border-soft\">\n<span class=\"w-2 h-2 rounded-full bg-success-green animate-pulse\"></span>\n<span class=\"font-metadata text-metadata text-text-secondary uppercase\">Live Feed Synchronized</span>\n</div>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 bg-[#FBFCFE] border-t border-slate-200\">\n<!-- Sessions (Active) -->\n<a class=\"flex flex-col items-center justify-center text-[#102033] bg-slate-100 rounded-lg py-1 px-3 active:scale-95 transition-transform duration-200\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"forum\" style=\"font-variation-settings: 'FILL' 1;\">forum</span>\n<span class=\"font-['Plus_Jakarta_SANS'] text-[11px] font-medium uppercase tracking-wider mt-1\">Sessions</span>\n</a>\n<!-- Inventory -->\n<a class=\"flex flex-col items-center justify-center text-slate-500 py-1 px-3 active:scale-95 transition-transform duration-200 hover:text-[#102033]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"inventory_2\">inventory_2</span>\n<span class=\"font-['Plus_Jakarta_SANS'] text-[11px] font-medium uppercase tracking-wider mt-1\">Inventory</span>\n</a>\n<!-- Stats -->\n<a class=\"flex flex-col items-center justify-center text-slate-500 py-1 px-3 active:scale-95 transition-transform duration-200 hover:text-[#102033]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"bar_chart\">bar_chart</span>\n<span class=\"font-['Plus_Jakarta_SANS'] text-[11px] font-medium uppercase tracking-wider mt-1\">Stats</span>\n</a>\n<!-- Profile -->\n<a class=\"flex flex-col items-center justify-center text-slate-500 py-1 px-3 active:scale-95 transition-transform duration-200 hover:text-[#102033]\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Plus_Jakarta_SANS'] text-[11px] font-medium uppercase tracking-wider mt-1\">Profile</span>\n</a>\n</nav>\n</body></html>",
