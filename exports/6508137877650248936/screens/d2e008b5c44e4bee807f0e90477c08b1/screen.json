  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=IBM+Plex+Mono:wght@400;600&amp;family=Work+Sans:wght@400;500;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            font-family: 'Work Sans', sans-serif;\n            -webkit-font-smoothing: antialiased;\n        }\n    </style>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    \"colors\": {\n                        \"on-primary\": \"#ffffff\",\n                        \"on-error\": \"#ffffff\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"primary-fixed-dim\": \"#b8c8e1\",\n                        \"error\": \"#ba1a1a\",\n                        \"secondary-fixed\": \"#dbe1ff\",\n                        \"container-active-text\": \"#1D4ED8\",\n                        \"primary-fixed\": \"#d4e4fe\",\n                        \"primary\": \"#000714\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"success-green\": \"#167A55\",\n                        \"container-waiting-bg\": \"#FFF4D6\",\n                        \"on-surface\": \"#1b1b1d\",\n                        \"inver