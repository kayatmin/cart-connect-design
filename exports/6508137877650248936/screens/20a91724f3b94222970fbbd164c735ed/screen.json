ky top-0 bg-[#FFFFFF] dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800\">\n<div class=\"flex items-center gap-3\">\n<button class=\"flex items-center justify-center w-touch-target-min h-touch-target-min text-[#102033] dark:text-slate-100 active:opacity-80 transition-opacity\">\n<span class=\"material-symbols-outlined\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<h1 class=\"font-['Plus_Jakarta_Sans'] font-extrabold text-[#102033] tracking-tighter text-lg dark:text-white\">CartConnect</h1>\n</div>\n<div class=\"flex items-center\">\n<button class=\"flex items-center justify-center w-touch-target-min h-touch-target-min text-[#102033] dark:text-slate-100 active:opacity-80 transition-opacity\">\n<span class=\"material-symbols-outlined\" data-icon=\"notifications\">notifications</span>\n</button>\n</div>\n</header>\n<main class=\"flex flex-col min-h-[calc(100vh-52px)] pb-3xl\">\n<!-- Header Summary Section -->\n<section class=\"bg-surface-white px-page-margin py-lg border-b border-border-soft\">\n<div class=\"flex justify-between items-start mb-md\">\n<div class=\"flex flex-col\">\n<span class=\"font-label text-text-tertiary uppercase tracking-wider mb-xs\">Customer</span>\n<h2 class=\"font-screen-title text-screen-title text-primary\">Julian R.</h2>\n</div>\n<div class=\"flex flex-col items-end\">\n<span class=\"inline-flex items-center px-sm py-2xs rounded-full bg-container-active-bg text-container-active-text font-label\">\n<span class=\"w-2 h-2 rounded-full bg-secondary mr-sm\"></span>\n                        Active\n                    </span>\n<span class=\"font-data-tabular text-data-tabular text-text-secondary mt-sm\">04:12</span>\n</div>\n</div>\n<div class=\"flex items-center justify-between p-md bg-surface-raised rounded-lg border border-border-soft\">\n<div class=\"flex flex-col\">\n<span class=\"font-label text-text-tertiary\">Cart Subtotal</span>\n<span class=\"font-display text-display text-primary\">$142.50</span>\n</div>\n<div class=\"flex gap-2\">\n<button class=\"h-button-height px-lg bg-primary text-white font-body-strong rounded-lg flex items-center justify-center active:scale-95 transition-transform\">\n                        Accept\n                    </button>\n<button class=\"h-button-height px-lg border border-border-soft text-danger-red font-body-strong rounded-lg flex items-center justify-center active:scale-95 transition-transform\">\n                        Decline\n                    </button>\n</div>\n</div>\n<button class=\"w-full mt-sm py-sm text-text-secondary font-label flex items-center justify-center gap-sm active:opacity-60\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"logout\">logout</span>\n                End Session\n            </button>\n</section>\n<!-- Chat Timeline -->\n<section class=\"flex-grow flex flex-col gap-section-gap px-page-margin py-xl bg-bg-base\">\n<div class=\"flex flex-col items-center\">\n<span class=\"px-md py-2xs bg-surface-muted text-text-tertiary font-metadata rounded-full\">Session started at 14:02</span>\n</div>\n<!-- Customer Message -->\n<div class=\"flex flex-col max-w-[85%] self-start\">\n<div class=\"flex items-center gap-sm mb-xs\">\n<span class=\"font-label text-text-secondary\">Julian R.</span>\n<span class=\"font-data-tabular text-metadata text-text-tertiary\">14:03</span>\n</div>\n<div class=\"bg-surface-white p-md rounded-xl rounded-tl-none border border-border-soft shadow-sm\">\n<p class=\"font-body text-on-surface\">Hello! I'm looking for high-quality headphones and a reliable USB-C cable for my laptop. Any recommendations?</p>\n</div>\n</div>\n<!-- Agent Message -->\n<div class=\"flex flex-col max-w-[85%] self-end\">\n<div class=\"flex items-center justify-end gap-sm mb-xs\">\n<span class=\"font-data-tabular text-metadata text-text-tertiary\">14:05</span>\n<span class=\"font-label text-primary-container\">Sarah (Agent)</span>\n</div>\n<div class=\"bg-primary-container p-md rounded-xl rounded-tr-none shadow-sm\">\n<p class=\"font-body text-surface-bright\">Of course, Julian! I've added our top-rated Premium Wireless Headphones and a reinforced USB-C cable to your cart. They are both highly durable and great for daily use.</p>\n</div>\n</div>\n<!-- Customer Message -->\n<div class=\"flex flex-col max-w-[85%] self-start\">\n<div class=\"flex items-center gap-sm mb-xs\">\n<span class=\"font-label text-text-secondary\">Julian R.</span>\n<span class=\"font-data-tabular text-metadata text-text-tertiary\">14:06</span>\n</div>\n<div class=\"bg-surface-white p-md rounded-xl rounded-tl-none border border-border-soft shadow-sm\">\n<p class=\"font-body text-on-surface\">That looks great. Can you check if the headphones have noise cancellation?</p>\n</div>\n</div>\n</section>\n<!-- Cart Panel (Floating Sheet Style) -->\n<section class=\"mt-auto bg-surface-white rounded-t-xl border-t border-border-soft shadow-2xl overflow-hidden\">\n<div class=\"px-page-margin pt-lg pb-md flex justify-between items-center border-b border-border-soft bg-surface-raised\">\n<div class=\"flex items-center gap-sm\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"shopping_cart\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">shopping_cart</span>\n<h3 class=\"font-section-title text-section-title\">Current Cart</h3>\n<span class=\"ml-xs px-2 py-0.5 bg-secondary text-white rounded font-data-tabular text-xs\">2</span>\n</div>\n<button class=\"text-text-secondary w-touch-target-min h-touch-target-min flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" data-icon=\"expand_more\">expand_more</span>\n</button>\n</div>\n<div class=\"divide-y divide-border-soft\">\n<!-- Cart Item 1 -->\n<div class=\"p-page-margin flex gap-md\">\n<div class=\"w-16 h-16 bg-surface-muted rounded overflow-hidden flex-shrink-0 border border-border-soft\">\n<img alt=\"Premium Headphones\" class=\"w-full h-full object-cover\" data-alt=\"A close-up studio photograph of premium over-ear wireless headphones in a sleek matte black finish. The lighting is soft and cinematic, highlighting the professional industrial design and textured ear pads. The aesthetic is modern and high-end, aligned with a professional retail environment focused on quality audio equipment.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD_wSSr90adkwHg92-NDUz6lyn1SyLMTCb1Wr8r6EDxkXbyUGXA-oF8L-vigcz1cJp0S2SoDqmNv9pti1JF7EJynVOt4qZl1YqUXEYwacI_skFMWxxIAVDQ0sYrknyOPmbQGxU4jeAA51wv6Ibqs1T80eRDHZh7avf9tt1maYYn4eHdQAuVSc2JFH841C-enVSNb1Iaf8HtCDQF7qqFkVOU7tMm4KoiRf6rlmo8XjgXixoxdTFyEkX6zpOQnsLQVYyRAUQWBttnrqM\"/>\n</div>\n<div class=\"flex-grow flex flex-col justify-between\">\n<div class=\"flex justify-between items-start\">\n<div>\n<h4 class=\"font-card-title text-card-title text-primary leading-tight\">Premium Headphones</h4>\n<p class=\"font-metadata text-text-tertiary\">SKU: AUD-2940-BK</p>\n</div>\n<span class=\"font-data-tabular text-primary\">$129.00</span>\n</div>\n<div class=\"flex justify-between items-end mt-sm\">\n<div class=\"flex items-center bg-surface-muted rounded-lg border border-border-soft\">\n<button class=\"w-11 h-10 flex items-center justify-center text-text-secondary active:bg-slate-200 rounded-l-lg transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"remove\">remove</span>\n</button>\n<span class=\"w-10 text-center font-data-tabular text-primary\">1</span>\n<button class=\"w-11 h-10 flex items-center justify-center text-text-secondary active:bg-slate-200 rounded-r-lg transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"add\">add</span>\n</button>\n</div>\n<button class=\"h-10 px-md flex items-center justify-center text-danger-red font-label hover:bg-container-danger-bg rounded-lg transition-colors\">\n                                Remove\n                            </button>\n</div>\n</div>\n</div>\n<!-- Cart Item 2 -->\n<div class=\"p-page-margin flex gap-md\">\n<div class=\"w-16 h-16 bg-surface-muted rounded overflow-hidden flex-shrink-0 border border-border-soft\">\n<img alt=\"USB-C Cable\" class=\"w-full h-full object-cover\" data-alt=\"A detailed shot of a premium braided USB-C to USB-C charging cable coiled neatly against a neutral studio backdrop. The cable features reinforced silver-toned metal connectors and a durable black mesh texture. The lighting is bright and industrial, emphasizing the professional grade construction and utilitarian purpose of the tech accessory.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCd1DOmnNVuZRy0i3neQvljJpMt_TPFdWwiOBwUYNRegGl8MvLi722HMW-EpCQzo2uxBy8WDJcuIZXWgZ6rIXsp-6YPFDWTDZJ1K1It5DXMHektZQ4_OMB50n7eU46bCHO4__ve0lCm8gVSX1oaPLIA8_8DyP1zw0maLgE9QF9h_sAW3jc_5E_JAhygwfVWYeyzA9U-0XXidkMbcGy12BXXRUzzakcL8YvOqNqEWJxm_KxZYQmCdCg7t3U29RFic1K4gf0r9w5Yhk8\"/>\n</div>\n<div class=\"flex-grow flex flex-col justify-between\">\n<div class=\"flex justify-between items-start\">\n<div>\n<h4 class=\"font-card-title text-card-title text-primary leading-tight\">USB-C Cable (2m)</h4>\n<p class=\"font-metadata text-text-tertiary\">SKU: ACC-105-BRAID</p>\n</div>\n<span class=\"font-data-tabular text-primary\">$13.50</span>\n</div>\n<div class=\"flex justify-between items-end mt-sm\">\n<div class=\"flex items-center bg-surface-muted rounded-lg border border-border-soft\">\n<button class=\"w-11 h-10 flex items-center justify-center text-text-secondary active:bg-slate-200 rounded-l-lg transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"remove\">remove</span>\n</button>\n<span class=\"w-10 text-center font-data-tabular text-primary\">1</span>\n<button class=\"w-11 h-10 flex items-center justify-center text-text-secondary active:bg-slate-200 rounded-r-lg transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"add\">add</span>\n</button>\n</div>\n<button class=\"h-10 px-md flex items-center justify-center text-danger-red font-label hover:bg-container-danger-bg rounded-lg transition-colors\">\n                                Remove\n                            </button>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Chat Composer (Sticky) -->\n<div class=\"sticky bottom-0 bg-surface-raised border-t border-border-soft px-page-margin py-md flex items-end gap-sm z-50\">\n<div class=\"flex-grow bg-white border border-border-soft rounded-xl p-xs focus-within:ring-2 focus-within:ring-secondary/20 transition-shadow\">\n<textarea class=\"w-full border-none focus:ring-0 font-body text-body py-sm px-md resize-none\" placeholder=\"Type a message...\" rows=\"1\"></textarea>\n</div>\n<button class=\"w-button-height h-button-height flex-shrink-0 bg-primary text-white rounded-xl flex items-center justify-center active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"send\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">send</span>\n</button>\n</div>\n</main>\n<!-- Bottom Nav Bar (Shared Component Logic) -->\n<nav class=\"fixed bottom-0 left-0 w-full z-[60] flex justify-around items-center px-2 py-3 bg-[#FBFCFE] dark:bg-slate-950 border-t border-slate-200 dark:border-slate-800\">\n<div class=\"flex flex-col items-center justify-center text-[#102033] dark:text-white bg-slate-100 dark:bg-slate-800 rounded-lg py-1 w-full scale-95 duration-100\">\n<span class=\"material-symbols-outlined\" data-icon=\"forum\">forum</span>\n<span class=\"font-['Plus_Jakarta_Sans'] text-[11px] font-semibold uppercase tracking-wider\">Sessions</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-slate-500 dark:text-slate-400 py-1 w-full hover:text-[#102033] dark:hover:text-white\">\n<span class=\"material-symbols-outlined\" data-icon=\"inventory_2\">inventory_2</span>\n<span class=\"font-['Plus_Jakarta_Sans'] text-[11px] font-semibold uppercase tracking-wider\">Inventory</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-slate-500 dark:text-slate-400 py-1 w-full hover:text-[#102033] dark:hover:text-white\">\n<span class=\"material-symbols-outlined\" data-icon=\"analytics\">analytics</span>\n<span class=\"font-['Plus_Jakarta_Sans'] text-[11px] font-semibold uppercase tracking-wider\">Stats</span>\n</div>\n<div class=\"flex flex-col items-center justify-center text-slate-500 dark:text-slate-400 py-1 w-full hover:text-[#102033] dark:hover:text-white\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Plus_Jakarta_Sans'] text-[11px] font-semibold uppercase tracking-wider\">Profile</span>\n</div>\n</nav>\n</body></html>",
