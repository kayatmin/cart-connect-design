      \"surface-container-high\": \"#eae7e9\",\n                        \"warning-orange\": \"#8A5A00\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"error-container\": \"#ffdad6\",\n                        \"on-tertiary-fixed\": \"#2a1801\",\n                        \"container-active-bg\": \"#E8F0FF\",\n                        \"surface-dim\": \"#dbd9db\",\n                        \"container-waiting-text\": \"#6F4700\",\n                        \"on-error\": \"#ffffff\",\n                        \"waiting-amber\": \"#F2A900\",\n                        \"surface-container-highest\": \"#e4e2e4\",\n                        \"primary\": \"#000714\",\n                        \"on-error-container\": \"#93000a\",\n                        \"surface\": \"#fbf9fa\",\n                        \"on-surface-variant\": \"#44474c\",\n                        \"tertiary-fixed\": \"#ffddb9\",\n                        \"container-success-bg\": \"#E7F6EE\"\n                    },\n                    \"borderRadius\": {\n                        \"DEFAULT\": \"4px\",\n                        \"lg\": \"8px\",\n                        \"xl\": \"12px\",\n                        \"full\": \"9999px\"\n                    },\n                    \"spacing\": {\n                        \"page-margin\": \"16px\",\n                        \"xl\": \"24px\",\n                        \"button-height\": \"52px\",\n                        \"xs\": \"4px\",\n                        \"lg\": \"16px\",\n                        \"2xs\": \"2px\",\n                        \"2xl\": \"32px\",\n                        \"touch-target-min\": \"44px\",\n                        \"section-gap\": \"20px\",\n                        \"3xl\": \"48px\",\n                        \"md\": \"12px\",\n                        \"sm\": \"8px\"\n                    },\n                    \"fontFamily\": {\n                        \"screen-title\": [\"Plus Jakarta Sans\"],\n                        \"body-strong\": [\"Work Sans\"],\n                        \"display\": [\"Plus Jakarta Sans\"],\n                        \"data-tabular\": [\"IBM Plex Mono\"],\n                        \"section-title\": [\"Plus Jakarta Sans\"],\n                        \"card-title\": [\"Plus Jakarta Sans\"],\n                        \"metadata\": [\"Work Sans\"],\n                        \"label\": [\"Work Sans\"],\n                        \"body\": [\"Work Sans\"]\n                    },\n                    \"fontSize\": {\n                        \"screen-title\": [\"22px\", {\"lineHeight\": \"28px\", \"fontWeight\": \"700\"}],\n                        \"body-strong\": [\"14px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"600\"}],\n                        \"display\": [\"28px\", {\"lineHeight\": \"34px\", \"fontWeight\": \"700\"}],\n                        \"data-tabular\": [\"13px\", {\"lineHeight\": \"18px\", \"fontWeight\": \"600\"}],\n                        \"section-title\": [\"17px\", {\"lineHeight\": \"24px\", \"fontWeight\": \"700\"}],\n                        \"card-title\": [\"15px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"700\"}],\n                        \"metadata\": [\"11px\", {\"lineHeight\": \"14px\", \"fontWeight\": \"500\"}],\n                        \"label\": [\"12px\", {\"lineHeight\": \"16px\", \"fontWeight\": \"600\"}],\n                        \"body\": [\"14px\", {\"lineHeight\": \"20px\", \"fontWeight\": \"400\"}]\n                    }\n                },\n            },\n        }\n    </script>\n<style>\n        body {\n            background-color: #F6F7F9;\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .rail-amber {\n            border-left: 4px solid #F2A900;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"font-body text-text-primary antialiased min-h-screen flex flex-col\">\n<!-- TopAppBar -->\n<header class=\"bg-white dark:bg-[#102033] border-b border-slate-200 dark:border-slate-800 flex items-center h-14 w-full px-4 sticky top-0 z-50\">\n<div class=\"flex items-center gap-4\">\n<button class=\"transition-colors duration-200 active:opacity-70 p-2 -ml-2\">\n<span class=\"material-symbols-outlined text-[#102033] dark:text-slate-100\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<h1 class=\"font-['Plus_Jakarta_Sans'] font-bold text-base tracking-tight text-[#102033] dark:text-slate-100\">Connection Status</h1>\n</div>\n</header>\n<!-- Main Content Canvas -->\n<main class=\"flex-1 flex flex-col items-center justify-center p-page-margin\">\n<div class=\"w-full max-w-md\">\n<!-- Focused Error Card -->\n<div class=\"bg-surface-white border border-border-soft rounded-xl shadow-sm overflow-hidden rail-amber\">\n<div class=\"p-xl space-y-lg text-center flex flex-col items-center\">\n<!-- Industrial Status Icon Cluster -->\n<div class=\"w-20 h-20 bg-container-waiting-bg rounded-full flex items-center justify-center mb-md\">\n<span class=\"material-symbols-outlined text-waiting-amber text-5xl\" data-icon=\"signal_disconnected\" style=\"font-variation-settings: 'wght' 300;\">signal_disconnected</span>\n</div>\n<!-- Typography Stack -->\n<div class=\"space-y-sm\">\n<h2 class=\"font-screen-title text-screen-title text-ink-dark\">Connection Lost</h2>\n<p class=\"font-body text-body text-text-secondary max-w-[280px] mx-auto leading-relaxed\">\n                            We're having trouble reaching the server. Your station is ready to reconnect as soon as the signal returns.\n                        </p>\n</div>\n<!-- Network Details (Industrial Utilitarian Component) -->\n<div class=\"w-full bg-surface-raised border border-border-soft rounded-lg p-md mt-lg text-left\">\n<div class=\"flex justify-between items-center\">\n<span class=\"font-label text-label text-text-tertiary uppercase tracking-wider\">Station ID</span>\n<span class=\"font-data-tabular text-data-tabular text-ink-dark\">CC-RTL-8842</span>\n</div>\n<div class=\"flex justify-between items-center mt-2\">\n<span class=\"font-label text-label text-text-tertiary uppercase tracking-wider\">Status</span>\n<div class=\"flex items-center gap-xs\">\n<div class=\"w-2 h-2 rounded-full bg-waiting-amber\"></div>\n<span class=\"font-data-tabular text-data-tabular text-warning-orange\">Retrying...</span>\n</div>\n</div>\n</div>\n<!-- Action Block -->\n<div class=\"w-full pt-xl space-y-md\">\n<button class=\"w-full h-button-height bg-primary-container text-white font-body-strong text-body-strong rounded-lg shadow-sm active:scale-[0.98] transition-transform\">\n                            Retry Connection\n                        </button>\n<button class=\"w-full h-button-height bg-transparent text-text-secondary font-label text-label hover:text-ink-dark transition-colors\">\n                            Contact Support\n                        </button>\n</div>\n</div>\n</div>\n<!-- Contextual Help (Subtle industrial hint) -->\n<div class=\"mt-xl flex items-start gap-sm px-md\">\n<span class=\"material-symbols-outlined text-text-tertiary text-sm\" data-icon=\"info\">info</span>\n<p class=\"font-metadata text-metadata text-text-tertiary italic\">\n                    Local operations remain cached. Transactions will sync once communication is re-established.\n                </p>\n</div>\n</div>\n</main>\n<!-- Visual Asset (Industrial Illustration) -->\n<div class=\"w-full flex justify-center mb-32 opacity-20 pointer-events-none\">\n<div class=\"w-64 h-32 relative\">\n<img class=\"w-full h-full object-contain mix-blend-multiply\" data-alt=\"A clean, industrial server rack with blue and amber status lights glowing in a dimly lit, professional data center environment. The scene is shot with a shallow depth of field, emphasizing high-end hardware and professional maintenance. The lighting is cold and precise, reflecting a high-pressure operational command center aesthetic with muted tones of slate and steel.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBC_9QIHEzGtqb0CxBXzE9tJVzxq2kqN9zXzJKckcpZ7ZgLVEKQdY_-PF8m1-6jy9pKF6QzEr4ctVbCdmPAGputlR1szdq8KkflYYmowmFMmnWxQo36PI6qeubsgLXNK_Of4yY4BqH__GTAVeO0rwydvtZ3xUPDYSkp6KtZZuuBBgQNACkvkPHmEPoJPDLgwns6WWrN1-VjsI2cdoXzqnz0b0z8ewGMmoIHTv8NyV6xc5EGHpUiCN1eJREPSQNhZE6yHrLIQpXhRjM\"/>\n</div>\n</div>\n<!-- BottomNavBar -->\n<nav class=\"bg-[#FBFCFE] dark:bg-[#102033] border-t border-slate-200 dark:border-slate-800 fixed bottom-0 w-full z-50 flex justify-around items-center h-16 px-4 pb-safe\">\n<!-- Dashboard -->\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 pt-1.5 active:scale-95 transition-transform duration-150 hover:text-blue-500\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"grid_view\">grid_view</span>\n<span class=\"font-['Plus_Jakarta_Sans'] font-medium text-[11px]\">Dashboard</span>\n</a>\n<!-- Orders -->\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 pt-1.5 active:scale-95 transition-transform duration-150 hover:text-blue-500\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"receipt_long\">receipt_long</span>\n<span class=\"font-['Plus_Jakarta_Sans'] font-medium text-[11px]\">Orders</span>\n</a>\n<!-- Inventory -->\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 pt-1.5 active:scale-95 transition-transform duration-150 hover:text-blue-500\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"inventory_2\">inventory_2</span>\n<span class=\"font-['Plus_Jakarta_Sans'] font-medium text-[11px]\">Inventory</span>\n</a>\n<!-- Account -->\n<a class=\"flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 pt-1.5 active:scale-95 transition-transform duration-150 hover:text-blue-500\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Plus_Jakarta_Sans'] font-medium text-[11px]\">Account</span>\n</a>\n</nav>\n</body></html>",
