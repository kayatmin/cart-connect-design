  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Work+Sans:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    \"colors\": {\n                        \"surface-white\": \"#FFFFFF\",\n                        \"outline-variant\": \"#c4c6cd\",\n                        \"on-secondary-fixed\": \"#00174b\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"success-green\": \"#167A55\",\n                        \"primary-fixed\": \"#d4e4fe\",\n                        \"surface-tint\": \"#505f75\",\n                        \"primary-fixed-dim\": \"#b8c8e1\",\n                        \"tertiary-container\": \"#2e1b03\",\n                        \"surface-bright\": \"#fbf9fa\",\n                        \"surface-muted\": \"#EEF1F5\",\n                        \"tertiary\": \"#0d0500\",\n                        \"secondary-fixed-dim\": \"#b4c5ff\",\n                        \"on-primary\": \"#ffffff\",\n                        \"on-tertiary-fixed-variant\": \"#5a4225\",\n                        \"on-primary-fixed-variant\": \"#39485d\",\n                        \"text-secondary\": \"#586174\",\n                        \"on-ter