  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Edit Cart - CartConnect</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Work+Sans:wght@400;500&amp;family=Space+Grotesk:wght@500&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    \"colors\": {\n                        \"on-surface-variant\": \"#44474c\",\n                        \"on-primary-fixed-variant\": \"#39485d\",\n                        \"error-container\": \"#ffdad6\",\n                        \"tertiary-fixed-dim\": \"#ffba3b\",\n                        \"primary-fixed\": \"#d4e4fe\",\n                        \"on-tertiary-container\": \"#b37c00\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"inverse-primary\": \"#b8c8e1\",\n                        \"on-primary\": \"#ffffff\",\n                        \"secondary-fixed\": \"#dbe1ff\",\n                        \"on-surface\": \"#131c2c\",\n                        \"inverse-on-surface\": \"#ecf0ff\",\n                        \"tertiary-container\": \"#2d1c00\",\n                        \"surface-container\": \"#e8eeff\",\n                        \"primary-container\": \"#102033\",\n                        \"outline\": \"#74777d\",\n                        \"secondary-container\": \"#316bf3\",\n                        \"secondary-fixed-dim\": \"#b4c5ff\",\n                     