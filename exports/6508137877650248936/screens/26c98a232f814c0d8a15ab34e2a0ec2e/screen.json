ht' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            background-color: #F6F7F9;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"antialiased text-on-surface font-body-base\">\n<!-- Top Navigation Header -->\n<header class=\"fixed top-0 w-full z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 h-16 flex items-center justify-between px-4\">\n<div class=\"flex items-center gap-3\">\n<button class=\"w-11 h-11 flex items-center justify-center rounded-full hover:bg-slate-50 active:opacity-70 transition-colors\">\n<span class=\"material-symbols-outlined text-slate-900 dark:text-white\">arrow_back</span>\n</button>\n<h1 class=\"font-display-lg text-headline-md text-slate-900 dark:text-white\">Edit Cart</h1>\n</div>\n<div class=\"flex items-center bg-surface-container-low px-3 py-1.5 rounded-full border border-outline-variant/30\">\n<span class=\"w-2 h-2 rounded-full bg-secondary mr-2\"></span>\n<span class=\"font-label-strong text-body-sm text-on-surface\">Julian R. • Active</span>\n</div>\n</header>\n<!-- Main Content Canvas -->\n<main class=\"pt-20 pb-40 px-4 max-w-md mx-auto space-y-4\">\n<!-- Cart Item 1 -->\n<div class=\"relative bg-white border border-[#DCE2EA] rounded-lg overflow-hidden group\">\n<div class=\"absolute left-0 top-0 bottom-0 w-1 bg-secondary\"></div>\n<div class=\"p-4 flex gap-4\">\n<div class=\"w-[56px] h-[56px] rounded-md overflow-hidden bg-slate-100 flex-shrink-0\">\n<img class=\"w-full h-full object-cover\" data-alt=\"A pair of high-end over-ear headphones in matte space grey finish, resting on a clean white professional studio surface. The lighting is soft and diffused, highlighting the metallic textures and premium build quality of the industrial design. The overall aesthetic is minimalist and modern, aligned with a corporate light-mode professional interface.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBY