cale-95 transition-transform\">\n<span class=\"material-symbols-outlined\">add_circle</span>\n                Add More Items\n            </button>\n</div>\n</main>\n<!-- Sticky Footer Summary -->\n<footer class=\"fixed bottom-0 w-full z-50 bg-white border-t border-[#DCE2EA] px-4 pt-4 pb-8 space-y-4\">\n<div class=\"max-w-md mx-auto\">\n<div class=\"flex items-center justify-between mb-4\">\n<span class=\"font-label-strong text-body-base text-on-surface-variant\">Subtotal (4 items)</span>\n<span class=\"font-data-mono text-headline-md text-slate-900\">$1,038.00</span>\n</div>\n<div class=\"flex flex-col gap-3\">\n<button class=\"w-full bg-[#102033] text-white font-label-strong h-[52px] rounded-lg flex items-center justify-center active:scale-95 transition-transform\">\n                    Ready for Checkout\n                </button>\n<button class=\"w-full bg-transparent border border-[#DCE2EA] text-on-surface font-label-strong h-[52px] rounded-lg flex items-center justify-center active:bg-slate-50 transition-colors\">\n                    Save Changes\n                </button>\n</div>\n</div>\n</footer>\n</body></html>",
