x-col items-center\">\n<!-- Icon Container (Tonal Layering Level 2) -->\n<div class=\"w-16 h-16 rounded-xl bg-container-active flex items-center justify-center mb-section-gap\">\n<span class=\"material-symbols-outlined text-secondary !text-3xl\" style=\"font-variation-settings: 'FILL' 1;\">lock</span>\n</div>\n<!-- Headline -->\n<h1 class=\"font-screen-title text-screen-title text-primary-container mb-sm\">\n                Session Expired\n            </h1>\n<!-- Body Message -->\n<p class=\"font-body text-body text-on-primary-container max-w-[280px] mb-3xl\">\n                For your security, your session has timed out. Please sign in again to continue managing your queue.\n            </p>\n<!-- Primary Action -->\n<button class=\"w-full h-[52px] bg-primary-container text-on-primary font-body-strong text-body-strong rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center\">\n                Sign in again\n            </button>\n<!-- Helpful Hint (Quiet industrial detail) -->\n<div class=\"mt-xl p-card-padding bg-surface-muted rounded border border-border-soft w-full\">\n<div class=\"flex items-start gap-sm\">\n<span class=\"material-symbols-outlined text-on-primary-container !text-sm mt-0.5\">info</span>\n<p class=\"font-metadata text-metadata text-on-primary-container text-left leading-relaxed\">\n                        Security policy requires re-authentication after 60 minutes of inactivity to protect sensitive merchant data.\n                    </p>\n</div>\n</div>\n</div>\n</main>\n<!-- Secondary Footer -->\n<footer class=\"py-xl flex flex-col items-center gap-sm\">\n<!-- Structural Detail: 4px Status Rail (Neutral) -->\n<div class=\"w-8 h-1 bg-border-soft rounded-full opacity-50 mb-sm\"></div>\n<p class=\"font-metadata text-metadata text-on-primary-container tracking-[0.1em] uppercase\">\n            CARTCONNECT SECURITY SERVICE\n        </p>\n</footer>\n</body></html>",
