<body class=\"bg-background-base min-h-screen flex flex-col font-body-md text-text-primary overflow-hidden\">\n<!-- TopAppBar Component (Immutable Identity) -->\n<header class=\"bg-slate-50 dark:bg-slate-950 flex items-center justify-between px-4 h-16 w-full border-b border-slate-200 dark:border-slate-800 fixed top-0 z-50\">\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-slate-900 dark:text-slate-50\" data-icon=\"shield_person\">shield_person</span>\n<span class=\"text-xl font-bold tracking-tighter text-slate-900 dark:text-slate-50 font-['Plus_Jakarta_Sans']\">CartConnect</span>\n</div>\n<div class=\"flex items-center\">\n<div class=\"w-2 h-2 rounded-full bg-clear-green mr-2\"></div>\n<span class=\"font-technical text-[10px] text-slate-500 uppercase tracking-widest\">System Ready</span>\n</div>\n</header>\n<!-- Main Content Canvas -->\n<main class=\"flex-grow flex flex-col items-center justify-center px-edge-margin pt-16 pb-12\">\n<!-- Brand Identity Section -->\n<div class=\"mb-10 text-center\">\n<div class=\"inline-flex items-center justify-center w-14 h-14 rounded-xl bg-ink-primary text-on-primary mb-4 shadow-sm\">\n<span class=\"material-symbols-outlined text-3xl\" data-icon=\"shopping_cart\">shopping_cart</span>\n</div>\n<h1 class=\"font-display-lg text-display-lg text-ink-primary tracking-tight\">Agent Console</h1>\n<p class=\"font-body-sm text-text-secondary mt-1\">Authorized access only for retail partners</p>\n</div>\n<!-- Login Form Card -->\n<div class=\"w-full max-w-sm bg-surface-main p-6 rounded-xl border border-border-soft shadow-sm\">\n<form class=\"space-y-5\">\n<div class=\"space-y-2\">\n<label class=\"font-['Source_Sans_3'] text-xs font-semibold uppercase tracking-wider text-text-tertiary\" for=\"email\">Email Address</label>\n<div class=\"relative\">\n<input class=\"w-full h-12 px-4 rounded-lg bg-surface-raised border border-border-soft focus:border-active-blue focus:ring-1 focus:ring-active-blue transition-all outline-none font-body-md text-text-primary placeholder:text-text-tertiary\" id=\"email\" name=\"email\" placeholder=\"agent@cartconnect.com\" type=\"email\"/>\n</div>\n</div>\n<div class=\"space-y-2\">\n<div class=\"flex justify-between items-center\">\n<label class=\"font-['Source_Sans_3'] text-xs font-semibold uppercase tracking-wider text-text-tertiary\" for=\"password\">Password</label>\n<a class=\"font-body-sm text-active-blue hover:underline\" href=\"#\">Forgot?</a>\n</div>\n<div class=\"relative\">\n<input class=\"w-full h-12 px-4 rounded-lg bg-surface-raised border border-border-soft focus:border-active-blue focus:ring-1 focus:ring-active-blue transition-all outline-none font-body-md text-text-primary placeholder:text-text-tertiary\" id=\"password\" name=\"password\" placeholder=\"••••••••\" type=\"password\"/>\n</div>\n</div>\n<div class=\"pt-2\">\n<button class=\"w-full h-[52px] bg-ink-primary text-on-primary font-['Source_Sans_3'] font-semibold rounded-lg hover:bg-on-primary-fixed-variant active:scale-[0.98] transition-all flex items-center justify-center gap-2\" type=\"submit\">\n<span>Sign In</span>\n<span class=\"material-symbols-outlined text-xl\" data-icon=\"login\">login</span>\n</button>\n</div>\n<div class=\"relative py-2\">\n<div aria-hidden=\"true\" class=\"absolute inset-0 flex items-center\">\n<div class=\"w-full border-t border-border-soft\"></div>\n</div>\n<div class=\"relative flex justify-center\">\n<span class=\"bg-surface-main px-2 text-xs font-technical text-text-tertiary uppercase\">SSO Authentication</span>\n</div>\n</div>\n<button class=\"w-full h-12 border border-border-soft bg-surface-main text-ink-primary font-['Source_Sans_3'] font-semibold rounded-lg hover:bg-slate-50 transition-colors flex items-center justify-center gap-2\" type=\"button\">\n<span class=\"material-symbols-outlined text-xl\" data-icon=\"key\">key</span>\n<span>Corporate SSO</span>\n</button>\n</form>\n</div>\n<!-- Visual Anchor (Asymmetric/Premium Detail) -->\n<div class=\"mt-8 grid grid-cols-2 gap-4 w-full max-w-sm\">\n<div class=\"h-24 rounded-xl border border-border-soft bg-surface-main flex flex-col items-center justify-center p-3\">\n<span class=\"material-symbols-outlined text-active-blue mb-1\" data-icon=\"bolt\">bolt</span>\n<span class=\"font-technical text-[10px] text-text-tertiary uppercase text-center\">Low Latency<br/>Protocol</span>\n</div>\n<div class=\"h-24 rounded-xl border border-border-soft bg-surface-main flex flex-col items-center justify-center p-3\">\n<span class=\"material-symbols-outlined text-clear-green mb-1\" data-icon=\"verified_user\">verified_user</span>\n<span class=\"font-technical text-[10px] text-text-tertiary uppercase text-center\">End-to-End<br/>Secure</span>\n</div>\n</div>\n</main>\n<!-- Footer Component (Structural Logic Execution) -->\n<footer class=\"bg-transparent fixed bottom-0 w-full flex flex-col items-center gap-1 pb-6 opacity-80 hover:opacity-100 transition-opacity\">\n<div class=\"flex items-center gap-4\">\n<span class=\"font-technical text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-600\">Environment: Production</span>\n<div class=\"w-1 h-1 rounded-full bg-slate-300\"></div>\n<span class=\"font-technical text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-600\">API Status: Optimal</span>\n</div>\n<p class=\"font-technical text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-600\">CartConnect v2.4.0-stable</p>\n</footer>\n<!-- Background Image Asset (Hidden context for rendering) -->\n<div class=\"fixed inset-0 -z-10 opacity-5 pointer-events-none overflow-hidden\">\n<img class=\"w-full h-full object-cover grayscale\" data-alt=\"A macro close-up of a high-tech control panel with subtle glowing blue indicators and precise mechanical buttons in an industrial setting. The lighting is cold and professional, utilizing a palette of deep navy, slate gray, and crisp white to match a premium enterprise software aesthetic. The atmosphere is quiet, focused, and suggests high-stakes operational reliability. Each detail of the texture is rendered with razor-sharp clarity and a matte finish.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB9TZ7_-Zta7TvSWe0yeqFWFLcf4BxbYP0bWNE3hp_JoNROdbhH8K6pQrGGrZeCH5JeeZB8p0MIZAt5lvl1arbYV1bglPCFXIViATQAaoS69oGkckX1CDPF5B_pEpxISG9HC9rSoQ9wExA9fKMyrMfwLL6NByWkQpv97U1EvjA5W_TiRLHhkgF7FBxy-UYex4LdiEwDoFEG8UqZZEoY_ZddDMmd5VOFjWfWsY5cUWo07sEO82v4oKpc_PIJpSlCM5_v3knbAVnvsco\"/>\n</div>\n</body></html>",
