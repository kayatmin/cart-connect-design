  "htmlContent": "<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>CartConnect Agent Login</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@500&amp;family=Source+Sans+3:wght@400;600&amp;family=IBM+Plex+Mono&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n    </style>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    \"colors\": {\n                        \"on-primary-fixed\": \"#0c1c2f\",\n                        \"outline-variant\": \"#c4c6cd\",\n                        \"surface-container-low\": \"#f5f3f5\",\n                        \"active-blue\": \"#2563EB\",\n                        \"inverse-surface\": \"#303032\",\n                        \"secondary-fixed-dim\": \"#b4c5ff\",\n                        \"surface-bright\": \"#fbf9fa\",\n                        \"on-primary\": \"#ffffff\",\n                        \"error\": \"#ba1a1a\",\n                        \"secondary-container\": \"#316bf3\",\n                        \"clear-green\": \"#167A55\",\n                        \"primary-fixed\": \"#d4e4fe\",\n                        \"on-error\": \"#ffffff\",\n                        \"background-base\": \"#F6F7F9\",\n                        \"surface-main\": \"#FFFFFF\",\n                        \"text-tertiary\": \"#8A94A6\",\n                        \"surface\": \"#fbf9fa\",\n                        \"inverse-on-surface\": \"#f2f0f2\",\n                        \"surface-container-highest\": \"#e4e2e4\",\n                        \"primary-fixed-dim\": \"#b8c8e1\",\n                        \"on-tertiary-container\": \"#a0815f\",\n                        \"inverse-primary\": \"#b8c8e1\",\n                        \"surface-tint\": \"#505f75\",\n                        \"tertiary-fixed-dim\": \"#e4c09a\",\n                        \"error-container\": \"#ffdad6\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"on-surface\": \"#1b1b1d\",\n                        \"primary\": \"#000714\",\n                        \"tertiary\": \"#0d0500\",\n                        \"ink-dark\": \"#07111F\",\n                        \"on-error-container\": \"#93000a\",\n                        \"text-secondary\": \"#586174\",\n                        \"tertiary-container\": \"#2e1b03\",\n                        \"text-primary\": \"#111827\",\n                        \"on-surface-variant\": \"#44474c\",\n                        \"background\": \"#fbf9fa\",\n                        \"on-secondary-fixed-variant\": \"#003ea8\",\n                        \"secondary-fixed\": \"#dbe1ff\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"ink-primary\": \"#102033\",\n                        \"surface-dim\": \"#dbd9db\",\n                        \"border-soft\": \"#DCE2EA\",\n                        \"on-secondary-fixed\": \"#00174b\",\n                        \"on-primary-container\": \"#78889f\",\n                        \"secondary\": \"#0051d5\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                